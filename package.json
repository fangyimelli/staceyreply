{
  "name": "staceyreply",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vite SPA entry: index.html -> src/main.tsx -> src/App.tsx",
  "scripts": {
    "predev": "npm run preprocess:data",
    "dev": "vite --host 127.0.0.1 --port 4173",
    "prebuild": "npm run preprocess:data",
    "build": "npm run check && vite build",
    "check": "tsc -p tsconfig.app.json --noEmit",
    "test": "node scripts/run-unified-scoring-tests.mjs",
    "preprocess:data": "node scripts/preprocess-data.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "start": "npm run dev"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
